# Healthcare Privacy Firewall — Environment Variables
# =====================================================

# Database
DATABASE_URL=postgresql+asyncpg://firewall_user:firewall_pass@postgres:5432/healthcare_firewall
DATABASE_SYNC_URL=postgresql+psycopg2://firewall_user:firewall_pass@postgres:5432/healthcare_firewall

# Redis
REDIS_URL=redis://redis:6379/0

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
API_SECRET_KEY=change-me-in-production

# Detection
SPACY_MODEL=en_core_web_sm
PRESIDIO_SCORE_THRESHOLD=0.5

# Audio
WHISPER_MODEL=base

# Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_MIN_RISK_SCORE=60.0

# Compliance
HIPAA_MODE=true
AUDIT_LOGGING=true
